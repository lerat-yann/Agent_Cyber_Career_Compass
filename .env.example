# Clé API Groq — gratuite sur https://console.groq.com
GROQ_API_KEY=votre_clé_groq_ici

# Optionnel : clé NVD pour augmenter le quota CVE (5 → 50 req/30s)
# Gratuite sur https://nvd.nist.gov/developers/request-an-api-key
# NVD_API_KEY=votre_clé_nvd_ici

# France Travail API (offres emploi cyber en temps réel)
# Credentials gratuits sur https://francetravail.io/inscription
FRANCE_TRAVAIL_CLIENT_ID=votre_client_id
FRANCE_TRAVAIL_CLIENT_SECRET=votre_client_secret
